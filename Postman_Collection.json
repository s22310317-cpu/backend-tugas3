{
    "info": {
        "name": "Auth JWT Spring Security API",
        "description": "Collection untuk testing Login & Registrasi dengan JWT Token",
        "version": "1.0.0"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Test@123\",\n    \"confirmPassword\": \"Test@123\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/auth/register",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Login User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"Test@123\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/auth/login",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Check Username Available",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "http://localhost:8080/api/auth/check-username/testuser",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "check-username",
                                "testuser"
                            ]
                        }
                    }
                },
                {
                    "name": "Check Email Available",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "http://localhost:8080/api/auth/check-email/test@example.com",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "check-email",
                                "test@example.com"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "Get Current User Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer YOUR_JWT_TOKEN_HERE",
                                "description": "Ganti dengan token yang didapat dari login"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/users/profile",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "users",
                                "profile"
                            ]
                        }
                    }
                },
                {
                    "name": "Test Protected Endpoint",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer YOUR_JWT_TOKEN_HERE",
                                "description": "Ganti dengan token yang didapat dari login"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/users/test",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "users",
                                "test"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Public Info",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "http://localhost:8080/api/users/public/info",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "users",
                                "public",
                                "info"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}
